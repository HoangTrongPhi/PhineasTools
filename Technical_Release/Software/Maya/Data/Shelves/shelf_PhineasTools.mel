        -command "import maya.cmds as cmds\nimport sys, os\nimport sys\nsys.path.append(r'C:/PhineasTools/Technical_Release')\nimport importlib\nimport Software.Maya.Toolsets.ThirdParty.Modeling.speedCut as speedCut\nimportlib.reload(speedCut)\n\n\n\n" 
