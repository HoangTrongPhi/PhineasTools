        -preventOverride 0
        -annotation "Tao vet gap Origami" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "polyFold" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "polyFold" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "C:/Users/trong/Documents/maya/2024/prefs/icons/polyFold.png" 
        -image1 "C:/Users/trong/Documents/maya/2024/prefs/icons/polyFold.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "##--------------------------------------------------------------------------\n##\n## ScriptName : polyFoldDoit\n## Contents   : fold polygon like paper\n## Author     : Joe Wu\n## URL        : https://www.youtube.com/@Im3dJoe\n## Since      : 2022/03/19\n## Version    : 1.01 public release\n## Version    : 1.02 fix bug when cluster created rename fail \n## hotKey      :\n##               + Ctrl          ----> fast rotate\n##               + Shift         ----> step with angle \n##--------------------------------------------------------------------------\n\n\nimport maya.cmds as mc\nimport math\nimport re\nimport maya.mel as mel\n\ndef polyFold():\n    if mc.window(\"polyFoldDoitUI\", exists = True):\n        mc.deleteUI(\"polyFoldDoitUI\")\n    polyFoldDoitUI = mc.window(\"polyFoldDoitUI\",title = \"polyFold 1.02\", w=340)\n    mc.frameLayout(labelVisible= False)\n    mc.text(l ='')\n    mc.rowColumnLayout(nc=15 ,cw=[(1,5),(2,80),(3,40),(4,5),(5,20),(6,5),(7,20),(8,5),(9,20),(10,5),(11,20),(12,5),(13,20),(14,5),(15,50)])\n    mc.text(l ='')\n    mc.text(l ='Snap Angle:')\n    mc.intField('snapAngleV', v = 15 )\n    mc.text(l ='')\n    mc.button( l= '5',  c= 'updateSNA(5)')\n    mc.text(l ='')\n    mc.button( l= '10', c= 'updateSNA(10)')\n    mc.text(l ='')\n    mc.button( l= '15', c= 'updateSNA(15)')\n    mc.text(l ='')\n    mc.button( l= '30', c= 'updateSNA(30)')\n    mc.text(l ='')\n    mc.button( l= '45', c= 'updateSNA(45)')\n    mc.text(l ='')\n    mc.iconTextButton(style='textOnly', l='Fold', rpt=1,bgc = [0.2,0.2,0.2], c='polyFoldDoit()')\n    mc.setParent( '..' )\n    mc.text(l ='')\n    mc.showWindow(polyFoldDoitUI)\n\n\ndef updateSNA(new):\n    mc.intField('snapAngleV', e=1, v = new )\n\n\ndef polyFoldDoit():\n    global snapStepping\n    global pfGeo\n    pfGeo = []\n    getSV =  mc.intField('snapAngleV', q=1, v =1 )\n    snapStepping = getSV\n    checCurrentkHUD =  mc.headsUpDisplay(lh=1)\n    if checCurrentkHUD is not None:\n        for t in checCurrentkHUD:\n            mc.headsUpDisplay(t, rem=1)\n    global ctx\n    ctx = 'plCtx'\n    # Delete dragger context if it already exists\n    if mc.draggerContext(ctx, exists=True):\n        mc.deleteUI(ctx)\n    # Create dragger context and set it to the active tool\n    mc.draggerContext(ctx, pressCommand = pfPress, rc = pfOff, dragCommand = pfDrag, name=ctx, cursor='crossHair',undoMode='step')\n    mc.setToolTo(ctx)\n\ndef pfOff():\n    global pfGeo\n    mc.delete(pfGeo[0], ch=1)\n    mc.headsUpDisplay( 'HUDunFoldStep',rem=True)\n    cleanList = ('rotOffset','rotBase','rotCC')\n    for c in cleanList:\n        if mc.objExists(c):\n            mc.delete(c)\n    mc.setToolTo('selectSuperContext')\n\ndef currentStep():\n    global viewPortCount\n    return viewPortCount\n\ndef pfPress():\n    global ctx\n    global screenX,screenY\n    global lockCount\n    global storeCount\n    global viewPortCount\n    global pfGeo\n    viewPortCount = 0\n    lockCount = 50\n    storeCount = 0\n    vpX, vpY, _ = mc.draggerContext(ctx, query=True, anchorPoint=True)\n    screenX = vpX\n    screenY = vpY\n    lockX = vpX\n    mc.headsUpDisplay( 'HUDunFoldStep', section=1, block=0, blockSize='large', label='Fold Angle', labelFontSize='large', command=currentStep, atr=1)\n    selFace = []\n    selFace = mc.filterExpand(expand=True ,sm=34)\n    if selFace:\n        pfGeo = mc.ls(hl=1)\n        mc.delete(pfGeo[0], ch=1)\n    cleanList = ('rotOffset','rotBase','rotCC')\n    for c in cleanList:\n        if mc.objExists(c):\n            mc.delete(c)\n    selGeo = mc.ls(hl=1)\n    mc.ConvertSelectionToEdgePerimeter()\n    mc.polySelectConstraint(mode =2, type = 0x8000 ,where =2)\n    mc.polySelectConstraint(m =0,w=0)\n    getEdges = mc.ls(sl=1,fl=1)\n    midEdge = getEdges[int((len(getEdges)/2))]\n    mc.select(midEdge)\n    mc.polySelectConstraint(type=0x8000, propagate=4)\n    mc.polySelectConstraint(m =0,w=0,propagate=0)\n    contEdges = mc.ls(sl=1,fl=1)\n    commonList = list(set(getEdges) - (   set(getEdges) - set(contEdges)  )    )\n    mc.select(commonList)\n    listVtx = vtxLoopOrder(commonList)\n    pA = mc.pointPosition(listVtx[0], w =1)\n    pB = mc.pointPosition(listVtx[-1], w =1)\n    mc.group( em=True, name='rotBase')\n    mc.setAttr('rotBase.translateX',pA[0])\n    mc.setAttr('rotBase.translateY',pA[1])\n    mc.setAttr('rotBase.translateZ',pA[2])\n    mc.group( em=True, name='rotAim')\n    mc.setAttr('rotAim.translateX',pB[0])\n    mc.setAttr('rotAim.translateY',pB[1])\n    mc.setAttr('rotAim.translateZ',pB[2])\n    consNode = mc.aimConstraint(('rotAim'),('rotBase'),offset=[0,0,0], weight=1, aimVector=[1,0,0], upVector=[0,1,0], worldUpType='scene')\n    mc.select(selFace)\n    mc.CreateCluster()\n    checkClusterName = mc.ls(sl=1,fl=1,typ='transform')\n    mc.rename(checkClusterName, 'rotCC')\n    newNode = mc.duplicate('rotBase',rr=1)\n    mc.rename(newNode[0],'rotOffset')\n    mc.parent('rotOffset', 'rotBase')\n    mc.delete('rotBase',constraints=1)\n    mc.setAttr('rotOffset.rotateX',0)\n    mc.setAttr('rotOffset.rotateY',0)\n    mc.setAttr('rotOffset.rotateZ',0)\n    mc.parent('rotCC','rotOffset')\n    mc.select(selFace)\n    cmd = 'doMenuComponentSelection(\"' + pfGeo[0] +'\", \"facet\");'\n    mel.eval(cmd)\n    mc.delete('rotAim')\n    mc.setAttr('rotBase.visibility',0)\n\n\n\n\ndef pfDrag():\n    global screenX,screenY\n    global viewPortCount\n    global lockCount\n    global storeCount\n    global snapStepping\n    modifiers = mc.getModifiers()\n    vpX, vpY, _ = mc.draggerContext(ctx, query=True, dragPoint=True)\n    stepping = snapStepping\n    if(modifiers == 1):\n        if screenX > vpX:\n            lockCount = lockCount - 1\n        else:\n            lockCount = lockCount + 1\n        screenX = vpX\n\n        if lockCount < -360:\n            lockCount = 360\n        elif lockCount > 360:\n            lockCount = 360\n        getX = int(lockCount / stepping)*stepping\n        if storeCount != getX:\n            storeCount = getX\n            mc.setAttr('rotOffset.rotateX',storeCount)\n            viewPortCount = storeCount\n    elif(modifiers == 4):\n        if screenX > vpX:\n            lockCount = lockCount - 5\n        else:\n            lockCount = lockCount + 5\n        screenX = vpX\n\n        if lockCount < -360:\n            lockCount = 360\n        elif lockCount > 360:\n            lockCount = 360\n        getX = int(lockCount / stepping)*stepping\n        if storeCount != getX:\n            storeCount = getX\n            mc.setAttr('rotOffset.rotateX',storeCount)\n            viewPortCount = storeCount\n    else:\n        if screenX > vpX:\n            lockCount = lockCount -1\n        else:\n            lockCount = lockCount + 1\n        screenX = vpX\n        if lockCount < -360:\n            lockCount = 360\n        elif lockCount > 360:\n            lockCount = 360\n        mc.setAttr('rotOffset.rotateX',lockCount)\n        viewPortCount = lockCount\n\n    mc.refresh(f=True)\n\n\ndef vtxLoopOrder(edgelist):\n    selEdges = edgelist\n    #print(selEdges)\n    shapeNode = mc.listRelatives(selEdges[0], fullPath=True , parent=True )\n    transformNode = mc.listRelatives(shapeNode[0], fullPath=True , parent=True )\n    edgeNumberList = []\n    for a in selEdges:\n        checkNumber = ((a.split('.')[1]).split('\\n')[0]).split(' ')\n        for c in checkNumber:\n            findNumber = ''.join([n for n in c.split('|')[-1] if n.isdigit()])\n            if findNumber:\n                edgeNumberList.append(findNumber)\n    getNumber = []\n    for s in selEdges:\n        evlist = mc.polyInfo(s,ev=True)\n        checkNumber = ((evlist[0].split(':')[1]).split('\\n')[0]).split(' ')\n        for c in checkNumber:\n            findNumber = ''.join([n for n in c.split('|')[-1] if n.isdigit()])\n            if findNumber:\n                getNumber.append(findNumber)\n    dup = set([x for x in getNumber if getNumber.count(x) > 1])\n    getHeadTail = list(set(getNumber) - dup)\n    vftOrder = []\n    vftOrder.append(getHeadTail[0])\n    count = 0\n    while len(dup)> 0 and count < 100:\n        checkVtx = transformNode[0]+'.vtx['+ vftOrder[-1] + ']'\n        velist = mc.polyInfo(checkVtx,ve=True)\n        getNumber = []\n        checkNumber = ((velist[0].split(':')[1]).split('\\n')[0]).split(' ')\n        for c in checkNumber:\n            findNumber = ''.join([n for n in c.split('|')[-1] if n.isdigit()])\n            if findNumber:\n                getNumber.append(findNumber)\n        findNextEdge = []\n        for g in getNumber:\n            if g in edgeNumberList:\n                findNextEdge = g\n        edgeNumberList.remove(findNextEdge)\n        checkVtx = transformNode[0]+'.e['+ findNextEdge + ']'\n        findVtx = mc.polyInfo(checkVtx,ev=True)\n        getNumber = []\n        checkNumber = ((findVtx[0].split(':')[1]).split('\\n')[0]).split(' ')\n        for c in checkNumber:\n            findNumber = ''.join([n for n in c.split('|')[-1] if n.isdigit()])\n            if findNumber:\n                getNumber.append(findNumber)\n        gotNextVtx = []\n        for g in getNumber:\n            if g in dup:\n                gotNextVtx = g\n        dup.remove(gotNextVtx)\n        vftOrder.append(gotNextVtx)\n        count +=  1\n    vftOrder.append(getHeadTail[1])\n    finalList = []\n    for v in vftOrder:\n        finalList.append(transformNode[0]+'.vtx['+ v + ']' )\n    return finalList\n\n\npolyFold()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Thuat toan tim duong ngan nhat" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "polyEdgeShift" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "polyEdgeShift" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "C:/Users/trong/Documents/maya/2024/prefs/icons/polyEdgeShift.png" 
        -image1 "C:/Users/trong/Documents/maya/2024/prefs/icons/polyEdgeShift.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "##--------------------------------------------------------------------------\n##\n## ScriptName : poly Edge Shift\n## Author     : Joe Wu\n## URL        : https://www.youtube.com/@Im3dJoe\n## LastUpdate : 2023/03/31\n##            : spin edge loop or face plane without lose shape\n## Version    : 1.0  First version for public test\n##              1.01  bug fix\n##\n## Install    : copy and paste script into a python tab in maya script editor\n##--------------------------------------------------------------------------\n\nimport maya.cmds as mc\nimport math\nimport maya.OpenMaya as om\nimport maya.api.OpenMaya as OpenMaya\nimport re\nimport maya.mel as mel\n\n\ndef polyEdgeShift():\n    if mc.window(\"polyEdgeShiftUI\", exists = True):\n        mc.deleteUI(\"polyEdgeShiftUI\")\n    polyEdgeShiftUI = mc.window('polyEdgeShiftUI' , t = \"poly Edge Shift v1.01\", w = 280, h = 50, s = 1 ,mxb = False,mnb = False)\n    mc.columnLayout(adj=1)\n    mc.text(l='')\n    mc.rowColumnLayout(nc= 6 ,cw=[(1,20),(2,75),(3,10),(4,75),(5,5),(6,75)])\n    mc.text(l='')\n    mc.checkBox('polyEdgeShiftFlattenCheck',label=\"Flatten\", value= 1,cc='polyEdgeToggleFlatten()') \n    mc.text(l='')\n    mc.button('PESGo', l= \"Go\", c = 'polyEdgeShiftRun()',bgc = (0.24, 0.4, 0.25 ))\n    mc.text(l='')\n    mc.button('PESUndo', en=0, l= \"Undo\", bgc = (0.24, 0.24, 0.24), c =  'PEStempLoadPointData()' )\n    mc.showWindow(polyEdgeShiftUI)\n\n\ndef polyEdgeToggleFlatten():\n    global polyEdgeShiftFlatten\n    if mc.objExists(polyEdgeShiftFlatten):\n        checkCurrent = mc.checkBox('polyEdgeShiftFlattenCheck',q=1,value= 1) \n        if polyEdgeShiftFlatten:\n            if checkCurrent == 1.0:\n                mc.setAttr(polyEdgeShiftFlatten + \".shapeKeeper\", 0)\n            else:\n                mc.setAttr(polyEdgeShiftFlatten + \".shapeKeeper\", 1)\n\ndef polyEdgeShiftRun():\n    global cutFaceSpineCv\n    global cutFaceSpineEdge\n    global cutFaceSpineEdgeID\n    global dataDict\n    global keepStartSelection\n    global polyEdgeShiftFlatten\n    global polyEdgeShiftData\n    PEStempStorePointData()\n    dataDict =[]\n    cutFaceSpineCv = []\n    cutFaceSpineEdge = []\n    cutFaceSpineEdgeID = []\n    innerCvList = []\n    unwwantInnerEdge = []\n    keepStartSelection = []\n    polyEdgeShiftFlatten = ''\n    mc.button('PESGo',e=1, en=0,bgc=(0.24, 0.24, 0.24))\n    mc.button('PESUndo',e=1, en=0,bgc=(0.24, 0.24, 0.24))\n    flattenIt = mc.checkBox('polyEdgeShiftFlattenCheck',q=1, value= 1) \n    cleanList = ('cutPlane','snapPlane','showCutCurv*','shapeKeeper','shapeFlatten')\n    for c in cleanList:\n        if mc.objExists(c):\n            mc.delete(c)\n    \n    cutFaceSpineFace =  mc.filterExpand( sm=34)\n    cutFaceSpineEdge =  mc.filterExpand( sm=32)\n    selMesh = ''\n    if cutFaceSpineEdge:\n        keepStartSelection = cutFaceSpineEdge\n        cutFaceSpineCv = mc.polyListComponentConversion(cutFaceSpineEdge,fe=1, tv=1,)\n        cutFaceSpineCv = mc.ls(cutFaceSpineCv,fl=1)\n        unwwantInnerEdge = []\n        createCutPinkLine(cutFaceSpineEdge)\n        selMesh = cutFaceSpineEdge[0].split('.')[0]\n    if cutFaceSpineFace:\n        #create blendshape\n        keepStartSelection = cutFaceSpineFace\n        selMesh = cutFaceSpineFace[0].split('.')[0]\n        toSpinFace = []\n        cutFaceShapeMaster = selMesh\n        dulpicateMesh = mc.duplicate(selMesh,smartTransform=1,rr=1)\n        mc.rename(dulpicateMesh,'shapeKeeper')\n        mc.select(cutFaceSpineFace)\n        #mc.scale(0,1,1, cs=1, ls=1, r=1)\n        dulpicateMesh = mc.duplicate(selMesh,smartTransform=1,rr=1)\n        mc.rename(dulpicateMesh,'shapeFlatten')\n        for c in cutFaceSpineFace:\n            newName = c.replace(selMesh,'shapeFlatten')\n            toSpinFace.append(newName)\n        innerCvList = mc.polyListComponentConversion(toSpinFace, ff=1, fv=1, fe=1, fuv=1, fvf=1, tv=1, internal=1)\n        innerCvList = mc.ls(innerCvList,fl=1)\n        fullCvList = mc.polyListComponentConversion(toSpinFace, ff=1, fv=1, fe=1, fuv=1, fvf=1, tv=1)\n        fullCvList = mc.ls(fullCvList,fl=1)\n        cutFaceSpineCv = list(set(fullCvList)-set(innerCvList))\n        cutFaceSpineEdge = mc.polyListComponentConversion(toSpinFace, ff=1, te=1)\n        cutFaceSpineEdge = mc.ls(cutFaceSpineEdge,fl=1)\n        unwwantInnerEdge = mc.polyListComponentConversion(innerCvList, fv=1, te=1)  \n        unwwantInnerEdge = mc.ls(unwwantInnerEdge,fl=1)\n        innerEdge = mc.polyListComponentConversion(toSpinFace, ff=1, te=1, internal=1)\n        borderEdges = list(set(cutFaceSpineEdge)-set(innerEdge))\n        mc.select(cutFaceSpineFace)\n        mc.ConvertSelectionToEdgePerimeter()\n        borderEdge =  mc.filterExpand( sm=32)\n        createCutPinkLine(borderEdge)\n        \n    dataDict = []\n    verPosiDict = []\n    for b in cutFaceSpineCv:\n        aimPoint = mc.pointPosition(b,w=1)\n        edgeList = mc.polyListComponentConversion(b, fv=1, te=1)\n        edgeX = mc.ls(edgeList,fl=1)\n        getEdge = list(set(edgeX) - set(cutFaceSpineEdge))\n        cvList = mc.polyListComponentConversion(getEdge, fe=1, tv=1)\n        cvX =  mc.ls(cvList,fl=1)\n        getCV = list(set(cvX) - set(cutFaceSpineCv)-set(unwwantInnerEdge))\n        basePoint = mc.pointPosition(getCV[0],w=1)\n        vectBtwPnts= ((basePoint [0] -aimPoint [0])*-1), ((basePoint [1] -aimPoint [1])*-1), ((basePoint [2] -aimPoint [2])*-1)\n        vectorToFinish = om.MFloatVector(vectBtwPnts[0],vectBtwPnts[1],vectBtwPnts[2])\n        raySource = om.MFloatPoint(basePoint[0],basePoint[1],basePoint[2])\n        rayDirection = vectorToFinish\n        rayDirection = rayDirection.normal()\n        dataCollect = [b,raySource,rayDirection]\n        dataDict.append(dataCollect)\n        verPosiDict.append(aimPoint)\n    avgPosition = getAvgVertPosition(cutFaceSpineCv)\n    avgNormal = []\n    mesh = mc.polyCreateFacet(p=verPosiDict)\n    avgNormal   = getAvgFaceNormal(mesh[0]+'.f[0]')\n    if innerCvList:\n        mfloatVectorSum = om.MFloatVector()\n        for d in dataDict:\n            mfloatVectorSum += dataDict[0][2]\n        mfloatVectorAverage = mfloatVectorSum / len(dataDict)\n        for i in innerCvList:\n            basePoint = mc.pointPosition(i,w=1)\n            raySource = om.MFloatPoint(basePoint[0],basePoint[1],basePoint[2])\n            dataCollect = [i,raySource,mfloatVectorAverage]\n            dataDict.append(dataCollect)\n    mc.delete(mesh)\n    snapPlane = mc.polyPlane(sx=1,sy=1,n='cutPlane')[0]\n    snapPlaneParent = mc.group(name=\"snapPlane\")\n    attr = '{}.translate'.format(snapPlaneParent)\n    for i, axis in enumerate(['X', 'Y', 'Z']):\n        mc.setAttr('{}{}'.format(attr,axis), avgPosition[i])\n    attr = '{}.scale'.format(snapPlane)\n    for axis in ['X', 'Y', 'Z']:\n        mc.setAttr('{}{}'.format(attr,axis), 10000)\n    orientLocator = mc.spaceLocator()\n    attr = '{}.translate'.format(orientLocator[0])\n    for i, axis in enumerate(['X', 'Y', 'Z']):\n        mc.setAttr('{}{}'.format(attr,axis), avgPosition[i])\n    oc = mc.orientConstraint(selMesh, orientLocator, offset=(0,0,0))\n    mc.delete(oc)\n    mc.makeIdentity(apply=1, t=1, r=1, s=1, n=0, pn=1)\n    mc.move(avgNormal[0], avgNormal[1], avgNormal[2], orientLocator, r=1, os=1)\n    ac = mc.aimConstraint(orientLocator, snapPlaneParent, aimVector=[0,1,0])\n    offsetPVGrp = mc.group(em=True, name=\"offsetPVGrp\")\n    mc.matchTransform( orientLocator[0], 'snapPlane', rot=True)\n    # Match the group's position to the locator's position\n    mc.matchTransform(offsetPVGrp, orientLocator[0], pos=True,rot=True)\n    mc.parent(orientLocator,offsetPVGrp)\n    mc.setAttr(orientLocator[0]+'.translateY',10000)\n    mc.delete(ac, offsetPVGrp)\n    updateSpinFace()\n    if mc.objExists('shapeFlatten'):#edge mode\n        mc.transferAttributes('shapeFlatten',selMesh,transferPositions=True,transferNormals=False,transferUVs=False,transferColors=False,sampleSpace=4,sourceUvSpace=\"map1\",targetUvSpace=\"map1\",searchMethod=3,flipUVs=False,colorBorders=True)\n        mc.delete(selMesh ,ch=1)\n        polyEdgeShiftFlatten = mc.blendShape('shapeKeeper', 'shapeFlatten', selMesh)[0]\n        mc.setAttr(polyEdgeShiftFlatten + \".shapeFlatten\", 1)\n        mc.setAttr(polyEdgeShiftFlatten + \".shapeKeeper\", 1)\n    sellist = om.MSelectionList()\n    sellist.add('cutPlane')\n    node = om.MObject()\n    sellist.getDependNode(0, node)\n    cutFaceSpineEdgeID = om.MNodeMessage.addAttributeChangedCallback(node, spinCutFace)\n    mc.select('cutPlane')\n    hideList = ('cutPlane','shapeFlatten','shapeKeeper','snapPlane')\n    for c in hideList:\n        if mc.objExists(c):\n            mc.setAttr(c + '.visibility',0)\n            mc.setAttr(c + '.hiddenInOutliner',1)\n    mc.scriptJob (ro=1, event = [\"SelectionChanged\", killCallBackRun])\n    mc.setToolTo(\"Rotate\")\n    mc.undoInfo(ock=1)\n    polyEdgeToggleFlatten()\n    \n\n\n    \ndef createCutPinkLine(cutFaceSpineEdge):\n    sortEdgeLoopGrp =  getEdgeRingGroup(0,cutFaceSpineEdge)\n    i=1\n    for s in sortEdgeLoopGrp:\n        mc.select(s)\n        mc.polyToCurve(form=2, degree=1, conformToSmoothMeshPreview=1)\n        #mc.CreateCurveFromPoly()\n        mc.rename('showCutCurve_'+str(i))\n        curveName ='showCutCurve_'+str(i)\n        mc.setAttr('showCutCurve_Shape'  +str(i) + '.lineWidth', 5)\n        mc.setAttr('showCutCurve_Shape'  +str(i) + '.overrideEnabled', 1)\n        mc.setAttr('showCutCurve_Shape'  +str(i) + '.overrideRGBColors', 1)\n        mc.setAttr('showCutCurve_Shape'  +str(i) + '.overrideColorRGB', 1, 0 , 0.8)\n        mc.setAttr(curveName + '.hiddenInOutliner',1)\n        i= i+1\n\ndef killCallBackRun():\n    global keepStartSelection\n    global cutFaceSpineEdgeID\n    om.MMessage.removeCallback(cutFaceSpineEdgeID)\n    cleanList = ('cutPlane','snapPlane','showCutCurv*','shapeKeeper','shapeFlatten')\n    for c in cleanList:\n        if mc.objExists(c):\n            mc.delete(c)\n    selMesh =keepStartSelection[0].split('.')[0]\n    mc.delete(selMesh ,ch=1)\n    mc.select(keepStartSelection)\n    mc.undoInfo(cck=1)\n    cutFaceSpineFace =  mc.filterExpand( sm=34)\n    cutFaceSpineEdge =  mc.filterExpand( sm=32)\n    if cutFaceSpineFace:\n        mel.eval('doMenuComponentSelectionExt(\"' + selMesh + '\", \"facet\", 0);')\n    elif cutFaceSpineEdge:\n        mel.eval('doMenuComponentSelectionExt(\"' + selMesh + '\", \"edge\", 0);')\n    \n    mc.button('PESUndo',e=1, en=1,bgc = (0.4, 0.24, 0.25) )\n    mc.button('PESGo',e=1, en=1,bgc=(0.24, 0.4, 0.24))\n    \ndef spinCutFace(msg, m_plug, otherMplug, clientData):\n    #print(m_plug.partialName())\n    if 'r'  in m_plug.partialName() or 't' in m_plug.partialName():\n        updateSpinFace()\n\n\ndef getAvgVertPosition(vList):\n    totalPos = OpenMaya.MPoint(0., 0., 0.)\n    for vert in vList:\n        pos = OpenMaya.MPoint(mc.pointPosition(vert, world=True))\n        totalPos += pos\n    count = len(vList)\n    return list(totalPos / float(count))[0:3]\n\n\ndef getAvgFaceNormal(selFace):\n    face_normals = mc.polyInfo(selFace, fn=True)\n    normals = [[], [], []]\n    for normal in face_normals:\n        label, vertex, x, y, z = normal.split()\n        normals[0].append(float(x))\n        normals[1].append(float(y))\n        normals[2].append(float(z))    \n    normals_count = len(face_normals)\n    x_avg = sum(normals[0]) / normals_count\n    y_avg = sum(normals[1]) / normals_count\n    z_avg = sum(normals[2]) / normals_count\n    return x_avg, y_avg,z_avg\n\n\ndef getAvgVertNormal(cutFaceSpineCv):\n    total_normal = OpenMaya.MVector(0., 0., 0.)\n    for vertex in cutFaceSpineCv:\n        normal = mc.polyNormalPerVertex(vertex, query=True, normalXYZ=True)\n        normal_vector = OpenMaya.MVector(normal[0], normal[1], normal[2])\n        total_normal += normal_vector\n    average_normal = total_normal / len(cutFaceSpineCv)\n    avgNormal = (average_normal.x, average_normal.y, average_normal.z)\n    return avgNormal\n\ndef updateSpinFace():\n    global dataDict\n    selectionList = om.MSelectionList()\n    selectionList.add('cutPlane')\n    node = om.MDagPath()\n    selectionList.getDagPath( 0, node )\n    meshFn = om.MFnMesh()\n    meshFn.setObject( node )\n    for d in dataDict:     \n        aimPoint = mc.pointPosition(d[0],w=1)  \n        hitpoint = om.MFloatPoint()\n        finalX = []\n        finalY = []\n        finalZ = []\n        shortDistance = 10000000000\n        distanceBetween = 1000000000\n        intersection = meshFn.closestIntersection(\n            om.MFloatPoint(d[1]),\n            om.MFloatVector(d[2]),\n            None,\n            None,\n            False,\n            om.MSpace.kWorld,\n            99999,\n            False,\n            None,\n            hitpoint,\n            None,\n            None,\n            None,\n            None,\n            None)\n        if intersection:\n            x = hitpoint.x\n            y = hitpoint.y\n            z = hitpoint.z\n            distanceBetween = math.sqrt( ((float(aimPoint[0]) - x)**2)  + ((float(aimPoint[1]) - y)**2) + ((float(aimPoint[2]) - z)**2))\n            if distanceBetween < shortDistance:\n                shortDistance = distanceBetween\n            mc.move(x, y, z, d[0], a=1, ws=1)\n            \n        else:\n            shortDistance = 10000000000\n            distanceBetween = 1000000000\n            mfloatVectorReverse = -d[2]\n            intersection = meshFn.closestIntersection(\n                om.MFloatPoint(d[1]),\n                om.MFloatVector(mfloatVectorReverse),\n                None,\n                None,\n                False,\n                om.MSpace.kWorld,\n                99999,\n                False,\n                None,\n                hitpoint,\n                None,\n                None,\n                None,\n                None,\n                None)\n            if intersection:\n                x = hitpoint.x\n                y = hitpoint.y\n                z = hitpoint.z\n                distanceBetween = math.sqrt( ((float(aimPoint[0]) - x)**2)  + ((float(aimPoint[1]) - y)**2) + ((float(aimPoint[2]) - z)**2))\n                if distanceBetween < shortDistance:\n                    shortDistance = distanceBetween\n                mc.move(x, y, z, d[0], a=1, ws=1)\n\ndef getEdgeRingGroup(listSort,listInput):\n    selEdges = mc.ls(sl=1,fl=1)\n    trans = selEdges[0].split(\".\")[0]\n    e2vInfos = mc.polyInfo(selEdges, ev=True)\n    e2vDict = {}\n    fEdges = []\n    for info in e2vInfos:\n        evList = [ int(i) for i in re.findall('\\\\d+', info) ]\n        e2vDict.update(dict([(evList[0], evList[1:])]))\n    while True:\n        try:\n            startEdge, startVtxs = e2vDict.popitem()\n        except:\n            break\n        edgesGrp = [startEdge]\n        num = 0\n        for vtx in startVtxs:\n            curVtx = vtx\n            while True:\n\n                nextEdges = []\n                for k in e2vDict:\n                    if curVtx in e2vDict[k]:\n                        nextEdges.append(k)\n                if nextEdges:\n                    if len(nextEdges) == 1:\n                        if num == 0:\n                            edgesGrp.append(nextEdges[0])\n                        else:\n                            edgesGrp.insert(0, nextEdges[0])\n                        nextVtxs = e2vDict[nextEdges[0]]\n                        curVtx = [ vtx for vtx in nextVtxs if vtx != curVtx ][0]\n                        e2vDict.pop(nextEdges[0])\n                    else:\n                        break\n                else:\n                    break\n            num += 1\n        fEdges.append(edgesGrp)\n    retEdges =[]\n    for f in fEdges:\n        f= list(map(lambda x: (trans +\".e[\"+ str(x) +\"]\"), f))\n        retEdges.append(f)\n    if listSort == 1:\n        sortEdgeLoopOrder=[]\n        getCircleState,listVtx = vtxLoopOrderCheck(listInput)\n        for l in listVtx:\n            for r in retEdges:\n                checkCvList = mc.ls(mc.polyListComponentConversion( r,fe=True, tv=True), fl=True,l=True)\n                if l in checkCvList:\n                    sortEdgeLoopOrder.append(r)\n        return sortEdgeLoopOrder\n    else:\n        return retEdges\n\n\ndef PEStempStorePointData():\n    global polyEdgeShiftData\n    polyEdgeShiftData=[]\n    selPoint = []\n    selFace = mc.filterExpand(expand=True ,sm=34)\n    if selFace:\n        selPoint = mc.polyListComponentConversion(selFace, ff=1, tv=1)\n    \n    selEdge = mc.filterExpand(expand=True ,sm=32)\n    if selEdge:\n        selPoint = mc.polyListComponentConversion(selEdge, fe=1, tv=1)\n    selPoint = mc.ls(selPoint,fl=1)\n    if selPoint:\n        storePointData = ''\n        meshName = selPoint[0].split('.')[0]\n        shapeNode = mc.listRelatives(meshName, fullPath=True , c=True )\n        if not mc.attributeQuery('pointPosData', node = shapeNode[0], ex=True ):\n            mc.addAttr(shapeNode[0], ln='pointPosData',  dt= 'string')\n            mc.setAttr((shapeNode[0]+'.pointPosData'),e=True, keyable=True)\n        for s in selPoint:\n            xA, yA, zA = mc.pointPosition(s, w=1)\n            xA = round(xA,4)\n            yA = round(yA,4)\n            zA = round(zA,4)\n            storePointData = storePointData + (str(s) + ',' + str(xA) + ',' + str(yA) + ',' + str(zA) + '@')\n        polyEdgeShiftData = storePointData\n\n\ndef PEStempLoadPointData():\n    global polyEdgeShiftData\n    meshName = polyEdgeShiftData.split('.')[0]\n    if mc.objExists(meshName):\n        dataList = polyEdgeShiftData.split('@')\n        del dataList[-1]\n        for r in dataList:\n            rawData = r.split(',')\n            mc.move(float(rawData[1]), float(rawData[2]), float(rawData[3]),rawData[0] , a =True, ws=True)\n    mc.button('PESUndo',e=1, en=0,bgc = (0.24, 0.24, 0.24) )\n                    \npolyEdgeShift()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "mini SpeedCut" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "instantCut" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "instantCut" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "C:/Users/trong/Documents/maya/2024/prefs/icons/instantCut.png" 
        -image1 "C:/Users/trong/Documents/maya/2024/prefs/icons/instantCut.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "##--------------------------------------------------------------------------\n## ScriptName : instCut\n## Contents   : cut and split shape \n## Author     : Joe Wu\n## URL        : http://im3djoe.com\n## Since      : 2024/06\n## Version    : 1.0  First version for public test\n##              1.03 bug fix, bevel corner not correct in 2d / 3d mode\n##              1.04 bug fix, cut grid not stick on the surface, \n##                   snap edge not work,\n##                   keep grid after cut in 3d mode, grid color change when draw\n##                   cut grid not show when isolate selected mode \n##              1.05 ortho camera mode R&D \n##              1.10 The orthographic ( front, top, side)  cameras work in 2D mode now.\n##   \t\t\t\t Grid colour indication: Yellow moving grid, Blue Draw Shape                                           Blue is for the drawn shape.\n##\t\t\t\t\t Grid stays in the last position\n##\t\t\t\t\t Grid algin to nearest edge (ctrl + shift + click) \n##  \t\t\t\t Hit the G key to repeat cutting\n## Install    : copy and paste entire code to a pyhotn script editor run it.\n##              drag entire code to shelf to make a button.\n##              required Maya 2023 or above\n##--------------------------------------------------------------------------\nimport operator\nimport maya.cmds as mc\nimport maya.mel as mel\nimport maya.api.OpenMaya as om2\nimport maya.OpenMaya as om\nimport maya.OpenMayaUI as omui\nfrom maya.OpenMaya import MGlobal\nimport math\nimport maya.plugin.polyBoolean.booltoolUtils as btUtils; \nimport re\n\ndef X64():\n    cleanList = ('extudeCluster','tempExtrudeBlock','cutBlockShader','blockFizMesh')\n    for c in cleanList:\n        if mc.objExists(c):\n            mc.delete(c)\n    global fnMeshA\n    global targetMmesh\n    global cameraUsed\n    global clickNo\n    clickNo = 0\n    global oldShader\n    global recordHitPoint\n    targetMmesh = mc.ls(sl=1,fl=1)   \n    if targetMmesh:\n        shape_nodes = mc.listRelatives(targetMmesh[0], shapes=True, fullPath=True)\n        oldShader = mc.listConnections(shape_nodes, type='shadingEngine')[0]\n        if mc.objExists('instCutGrp') == 0 or cameraUsed == []:\n            X76()\n            X2l()\n        mc.setAttr(\"cutGirdLine.lineColor\", 1, 1, 0, type=\"double3\")\n        model_panels = mc.getPanel(type='modelPanel')\n        for m in model_panels:\n            state = mc.isolateSelect(m, q=1, s =1)\n            if state:\n                mc.isolateSelect(m, addDagObject= 'instCutGrp' )\n        curPanel = mc.getPanel(wf=1)\n        if not 'modelPanel' in curPanel:\n            curPanel = 'modelPanel4'\n        mc.modelEditor( curPanel,e=1, planes=1)\n        curCam = mc.modelPanel(curPanel,q=1, cam=1)\n        cameraPos = mc.xform(curCam,q=1,ws=1,t=1)\n        orthoValue = mc.camera(curCam,q=1, o=1)\n        planePos=[]\n        if orthoValue ==0:\n            camRot = mc.camera(curCam,q=1, rot=1)\n            camRotFixed = []\n            for i in range(2):\n                camRotTemp = camRot[i] / 360\n                intOfTemp = int(camRotTemp)\n                rotOver = 360 * intOfTemp\n                camRotFixed.append( camRot[i] - rotOver)\n            for i in range(2):\n                if camRotFixed[i] < 0 :\n                      camRotFixed[i]= camRotFixed[i] +360;\n            getCurrentCamera=[]\n            if (camRotFixed[0] >= 45 and camRotFixed[0] < 135):\n                getCurrentCamera = 'buttom'\n            elif (camRotFixed[0] >= 225 and camRotFixed[0] < 315):\n                getCurrentCamera = 'top'\n            elif (camRotFixed[1] < 45):\n                getCurrentCamera = 'front'\n            elif (camRotFixed[1] >= 315 ):\n                getCurrentCamera = 'front'\n            elif (camRotFixed[1] >= 45 and camRotFixed[1] < 135):\n                getCurrentCamera = 'right'\n            elif (camRotFixed[1] >= 135 and camRotFixed[1] < 225):\n                getCurrentCamera = 'back'\n            elif (camRotFixed[1] >= 225 and camRotFixed[1] < 315):\n                getCurrentCamera = 'left'\n            if cameraUsed != getCurrentCamera:\n                mc.setAttr(\"instCutGrp.rotateX\", 0)\n                mc.setAttr(\"instCutGrp.rotateY\", 0)\n                mc.setAttr(\"instCutGrp.rotateZ\", 0)\n                mesh = targetMmesh\n                bbox= mc.xform(mesh, q=1, ws=1, bb=1)\n                length=math.sqrt((math.pow(bbox[0]-bbox[3],2)+math.pow(bbox[1]-bbox[4],2)+math.pow(bbox[2]-bbox[5],2))/3)\n                length = int(length *1.1 )\n                meshCOORD = mc.objectCenter(mesh,gl=True)\n                constructionPlanePos=[]\n                if getCurrentCamera == 'front' or getCurrentCamera == 'back':\n                    if getCurrentCamera == 'front':\n                            planePos = bbox[5]\n                    elif getCurrentCamera == 'back':\n                        if (bbox[2] - cameraPos[2]) > 0:\n                            planePos = bbox[2]\n                    constructionPlanePos = [meshCOORD[0],meshCOORD[1],planePos*1.01]\n                elif  getCurrentCamera == 'top' or getCurrentCamera == 'buttom':# check y asix\n                    if getCurrentCamera == 'top':\n                        planePos = bbox[4]\n                    elif getCurrentCamera == 'buttom':\n                        planePos = bbox[1]\n                    constructionPlanePos = [meshCOORD[0],planePos*1.01,meshCOORD[2]]\n                elif  getCurrentCamera == 'left' or getCurrentCamera == 'right':# check x asix\n                    if getCurrentCamera == 'right':\n                        planePos = bbox[3]\n                    elif getCurrentCamera == 'left':\n                        planePos = bbox[0]\n                    constructionPlanePos = [planePos*1.01,meshCOORD[1],meshCOORD[2]]\n                mc.move(constructionPlanePos[0],constructionPlanePos[1],constructionPlanePos[2],'instCutGrp', absolute=True, ws=1)\n                recordHitPoint = (constructionPlanePos[0],constructionPlanePos[1],constructionPlanePos[2])\n                if getCurrentCamera == 'front':\n                    mc.setAttr(\"instCutGrp.rotateX\", 180)\n                elif getCurrentCamera == 'back':\n                    mc.setAttr(\"instCutGrp.rotateX\", 0)\n                elif  getCurrentCamera == 'top':\n                    mc.setAttr(\"instCutGrp.rotateX\", 90)\n                elif getCurrentCamera == 'buttom':\n                    mc.setAttr(\"instCutGrp.rotateX\", -90)\n                elif  getCurrentCamera == 'left':\n                    mc.setAttr(\"instCutGrp.rotateY\", 90)\n                elif getCurrentCamera == 'right':\n                    mc.setAttr(\"instCutGrp.rotateY\", -90)\n                cameraUsed = getCurrentCamera\n            else:\n                mc.move(recordHitPoint[0],recordHitPoint[1],recordHitPoint[2],'instCutGrp', absolute=True, ws=1)\n                if getCurrentCamera == 'front':\n                    mc.setAttr(\"instCutGrp.rotateX\", 180)\n                elif getCurrentCamera == 'back':\n                    mc.setAttr(\"instCutGrp.rotateX\", 0)\n                elif  getCurrentCamera == 'top':\n                    mc.setAttr(\"instCutGrp.rotateX\", 90)\n                elif getCurrentCamera == 'buttom':\n                    mc.setAttr(\"instCutGrp.rotateX\", -90)\n                elif  getCurrentCamera == 'left':\n                    mc.setAttr(\"instCutGrp.rotateY\", 90)\n                elif getCurrentCamera == 'right':\n                    mc.setAttr(\"instCutGrp.rotateY\", -90)\n            if mc.objExists('instCutPlane'):\n                selectionList = om.MSelectionList()\n                selectionList.add('instCutPlane')\n                dagPath = om.MDagPath()\n                selectionList.getDagPath(0, dagPath)\n                fnMeshA = om.MFnMesh(dagPath)\n                global ctxPlane\n                ctxPlane = 'drawPlane'\n                if mc.draggerContext(ctxPlane, exists=True):\n                    mc.deleteUI(ctxPlane)\n                mc.draggerContext(ctxPlane, pressCommand = X8I, rc = Xlo, dragCommand = X25, name=ctxPlane, fnz=X85, cursor='crossHair',undoMode='step')\n                mc.setToolTo(ctxPlane)\n                mc.scriptJob(runOnce=True, event=[\"ToolChanged\", X75])\n            X69()\n   \ndef Xl6():\n    state = mc.radioButtonGrp('cutPlane', q=1 , sl=1)\n    if state == 2:\n        mc.setAttr(( \"instCutPlane.rotateY\" ),0)\n    elif state == 3:\n        mc.setAttr(( \"instCutPlane.rotateZ\" ),0)\n    checkLongName = 'instCutGrp'\n    parentNode = 'instCutGrp'\n    cleanList = ('sampleCurv*','sampleMes*','rotationPlan*')\n    for c in cleanList:\n        if mc.objExists(c):\n            mc.delete(c)\n    gface, gHitp,cEdge,cEdgePos = X95()\n    checkCVList=mc.ls( mc.polyListComponentConversion (cEdge,fe=True,tv=True),flatten=True)\n    mx,my,mz = mc.pointPosition(checkCVList[0],w=1)\n    mc.polyPlane(w=1, h=1, sx=1, sy=1, ax=(0,1,0), cuv=2, ch=0, n='rotationPlane')\n    mc.polyCreateFacet( p=[(mx, my, mz),(cEdgePos[0], cEdgePos[1], cEdgePos[2]),(gHitp[0], gHitp[1], gHitp[2])] )\n    mc.rename('sampleMesh')\n    mc.select(\"rotationPlane.vtx[0:2]\", \"sampleMesh.vtx[0:2]\")\n    CMD = 'snap3PointsTo3Points(0);'\n    mel.eval(CMD)\n    mc.parent('instCutGrp','rotationPlane')\n    axes = [\"X\", \"Y\", \"Z\"]\n    for a in axes:\n        \n        val = mc.getAttr( \"instCutGrp.rotate\" + a)\n        valTmp = ''\n        if val > 0:\n            valTmp = val + 45\n        else:\n            valTmp = val - 45\n        valNew = int (valTmp/90)\n        mc.setAttr(( \"instCutGrp.rotate\" + a), (valNew*90))\n    mc.parent('instCutGrp',w=1)\n    mc.select(cl=1)\n    for c in cleanList:\n        if mc.objExists(c):\n            mc.delete(c)\n\n\ndef X95():\n    gFace = ''\n    gHitP = ''\n    gFace,gHitP = X93()\n    listF2E=mc.ls( mc.polyListComponentConversion (gFace,ff=True,te=True),flatten=True)\n    cEdge = ''\n    smallestDist = 1000000\n    cEdgePos = []\n    for l in listF2E:\n        mc.select(l)\n        mc.polyToCurve(form=2, degree=1, conformToSmoothMeshPreview=1)\n        sampleCurve = mc.ls(sl=1)\n        selectionList = om.MSelectionList()\n        selectionList.add(sampleCurve[0])\n        dagPath = om.MDagPath()\n        selectionList.getDagPath(0, dagPath)\n        omCurveOut = om.MFnNurbsCurve(dagPath)\n        pointInSpace = om.MPoint(gHitP[0],gHitP[1],gHitP[2])\n        closestPoint = om.MPoint()\n        closestPoint = omCurveOut.closestPoint(pointInSpace)\n        getDist = math.sqrt( ((closestPoint[0] - gHitP[0])**2)  + ((closestPoint[1]- gHitP[1])**2) + ((closestPoint[2] - gHitP[2])**2))\n        if getDist < smallestDist:\n            smallestDist = getDist\n            cEdge = l\n            cEdgePos = [closestPoint[0],closestPoint[1],closestPoint[2]]\n        mc.delete(sampleCurve)\n    mc.select(cEdge)\n    return(gFace,gHitP,cEdge,cEdgePos)\n\n\ndef X93():\n    global recordHitPoint\n    shortDistanceCheck = 10000\n    resultFace = []\n    resultCV =[]\n    resultHitPoint = []\n    getFaceDist,getFace,getHitPoint  = X52(recordHitPoint)\n    if getFaceDist < shortDistanceCheck:\n        shortDistanceCheck = getFaceDist\n        resultFace = getFace\n        resultHitPoint = getHitPoint\n    return (resultFace,resultHitPoint)\n\n\n\ndef X52(pos=[0,0,0]):\n    global targetMmesh\n    mVector = om2.MVector(pos)#using MVector type to represent position\n    selectionList = om2.MSelectionList()\n    selectionList.add(targetMmesh[0])\n    dPath= selectionList.getDagPath(0)\n    mMesh=om2.MFnMesh(dPath)\n    ID = mMesh.getClosestPoint(om2.MPoint(mVector),space=om2.MSpace.kWorld)[1] #getting closest face ID\n    closestPoint= mMesh.getClosestPoint(om2.MPoint(mVector),space=om2.MSpace.kWorld)[0]\n    cpx = closestPoint[0]\n    cpy = closestPoint[1]\n    cpz = closestPoint[2]\n    hitPointPosition = [cpx,cpy,cpz]\n    hitFaceName = (targetMmesh[0] +'.f['+str(ID)+']')\n    getFaceDist = math.sqrt( ((pos[0] - cpx)**2)  + ((pos[1]- cpy)**2) + ((pos[2] - cpz)**2))\n    return (getFaceDist, hitFaceName,hitPointPosition)\n\ndef X38(mesh, face_index):\n    selection = om.MSelectionList()\n    selection.add(mesh)\n    dagPath = om.MDagPath()\n    selection.getDagPath(0, dagPath)\n    fnMesh = om.MFnMesh(dagPath)\n    normal = om.MVector()\n    fnMesh.getPolygonNormal(face_index, normal, om.MSpace.kWorld)\n    return normal\n\n\ndef Xl7():\n    selectionListX = om.MSelectionList()\n    selectionListX.add('tempExtrudeBlock')\n    dagPathX = om.MDagPath()\n    selectionListX.getDagPath(0, dagPathX)\n    faceIter = om.MItMeshPolygon(dagPathX)\n    faceIndex = 0 \n    vertexListX = om.MIntArray()\n    faceIter.getVertices(vertexListX)\n    vtxList = [vertexListX[i] for i in range(vertexListX.length())]\n    zero_index = vtxList.index(0)\n    vtxList = vtxList[zero_index:] + vtxList[:zero_index]\n    return vtxList\n\ndef XOl():\n    VertexInitSelection = mc.ls(sl=1,fl=1)\n    EdgeSel = mc.ls(mc.polyListComponentConversion(VertexInitSelection, te=1),fl=1)\n    mc.select(EdgeSel)\n    mc.polyExtrudeEdge( EdgeSel, kft=True, pvx= 0, pvy= 0, pvz= 0, divisions= 1, twist= 0, taper= 1, offset= 0, thickness= 0)\n    newEdge = mc.ls(sl=1,fl=1)\n    converted = mc.polyListComponentConversion(mc.polyListComponentConversion(newEdge, tf=1), fv=True, ff=True, fuv=True, fvf=True, te=True, internal=True)\n    state = mc.radioButtonGrp('cutPlane',q=1, sl=1)\n    mVTolerance = 1\n    if state == 2:\n        mVTolerance = 0.001\n    createdNode = mc.polyBevel3(\n        converted,\n        fraction=0.5,\n        offsetAsFraction=True,\n        autoFit=True,\n        depth=1,\n        mitering=0,\n        miterAlong=0,\n        chamfer=True,\n        segments=1,\n        worldSpace=True,\n        smoothingAngle=30,\n        subdivideNgons=True,\n        mergeVertices=True,\n        mergeVertexTolerance=mVTolerance,\n        miteringAngle=180,\n        angleTolerance=180,\n        constructionHistory=True,\n        name = 'cutBevel'\n    )\n    mc.rename(createdNode,'cutBevel')\n    mc.select('tempExtrudeBlock')\n    mc.headsUpDisplay( 'HUDBevelStep', section=2, block=0, blockSize='large', label='Segments', labelFontSize='large', command=X68, atr=1)\n    #endBevelTool = mc.scriptJob(runOnce=True, event=[\"ToolChanged\", X27])\n\ndef X68():\n    if mc.objExists('cutBevel'):\n        current = mc.getAttr('cutBevel.segments')\n        return current\n        \ndef X78():\n    #global cutToolID\n    #mc.scriptJob(kill=cutToolID, force=True)\n    gP = Xl7()[-1]\n    vertex_count = mc.polyEvaluate('tempExtrudeBlock', vertex=True)\n    VertexInitSelection = 'tempExtrudeBlock.vtx['+ str(gP) +']'\n    EdgeSel = mc.ls(mc.polyListComponentConversion(VertexInitSelection, te=1),fl=1)\n    mc.select(EdgeSel)\n    mc.polyExtrudeEdge( EdgeSel, kft=True, pvx= 0, pvy= 0, pvz= 0, divisions= 1, twist= 0, taper= 1, offset= 0, thickness= 0)\n    newEdge = mc.ls(sl=1,fl=1)\n    converted = mc.polyListComponentConversion(mc.polyListComponentConversion(newEdge, tf=1), fv=True, ff=True, fuv=True, fvf=True, te=True, internal=True)\n    state = mc.radioButtonGrp('cutPlane',q=1, sl=1)\n    mVTolerance = 1\n    if state == 2:\n        mVTolerance = 0.001\n    createdNode = mc.polyBevel3(\n        converted[0],\n        fraction=0.5,\n        offsetAsFraction=True,\n        autoFit=True,\n        depth=1,\n        mitering=0,\n        miterAlong=0,\n        chamfer=True,\n        segments=1,\n        worldSpace=True,\n        smoothingAngle=30,\n        subdivideNgons=True,\n        mergeVertices=True,\n        mergeVertexTolerance=mVTolerance,\n        miteringAngle=180,\n        angleTolerance=180,\n        constructionHistory=True,\n        name = 'cutBevel'\n    )\n    mc.rename(createdNode,'cutBevel')\n    #mel.eval('dR_DoCmd(\"bevelPress\")')\n    mc.select('tempExtrudeBlock')\n    mc.headsUpDisplay( 'HUDBevelStep', section=2, block=0, blockSize='large', label='Segments', labelFontSize='large', command=X68, atr=1)\n    #endBevelTool = mc.scriptJob(runOnce=True, event=[\"ToolChanged\", X27])\n\n\ndef X27(): \n    global ctx\n    if mc.objExists('tempExtrudeBlock'):\n        mc.delete('tempExtrudeBlock',ch=1)\n        mc.select('tempExtrudeBlock')\n    mc.setToolTo(ctx)\n    mc.headsUpDisplay( 'HUDBevelStep',rem=True)\n    #cutToolID = mc.scriptJob(runOnce=True, event=[\"ToolChanged\", X34])  \n\ndef X58():\n    mc.scriptEditorInfo(suppressWarnings=1,suppressInfo=0,se=0)\n    global targetMmesh\n    global cameraUsed\n    state = mc.radioButtonGrp('cutPlane', q=1, sl=1)\n    testSel = mc.ls(sl=1,fl=1)\n    if testSel:\n        pass\n    else:\n        if targetMmesh:\n            mc.select(targetMmesh)\n    runCheck = mc.ls(sl=1,fl=1)\n    shapes = mc.listRelatives(runCheck, shapes=True, fullPath=True)\n    if mc.nodeType(shapes) == 'mesh':\n        mc.iconTextButton('instCutGo', e=1,en=0)\n        mc.radioButtonGrp('cutPlane', e=1,en=0)\n        targetMmesh = runCheck\n        if state == 1:\n            X55()\n        elif state == 2:\n            X26()\n        else:\n            X64()\n\ndef X26():\n    global extrudeNewMesh\n    extrudeNewMesh = []\n    global oldShader\n    global camPivot\n    global cameraTrans\n    global clickNo\n    clickNo = 0\n    global fnMeshA\n    global targetMmesh\n    global cutToolID\n    global recordAlignAngle\n    recordAlignAngle = 0\n    global recordHitFaceName\n    recordHitFaceName = []\n    cleanList = ('extudeCluster','tempExtrudeBlock','cutBlockShader','blockFizMesh')\n    for c in cleanList:\n        if mc.objExists(c):\n            mc.delete(c)\n    targetMmesh = mc.ls(sl=1,fl=1)            \n    if targetMmesh:\n        shape_nodes = mc.listRelatives(targetMmesh[0], shapes=True, fullPath=True)\n        oldShader = mc.listConnections(shape_nodes, type='shadingEngine')[0]\n        if mc.objExists('instCutGrp') == 0:\n            X76()\n            X2l()\n        mc.setAttr(\"cutGirdLine.lineColor\", 1, 1, 0, type=\"double3\")\n        model_panels = mc.getPanel(type='modelPanel')\n        for m in model_panels:\n            state = mc.isolateSelect(m, q=1, s =1)\n            if state:\n                mc.isolateSelect(m, addDagObject= 'instCutGrp' )\n        view = omui.M3dView.active3dView()\n        cam = om.MDagPath()\n        view.getCamera(cam)\n        camPath = cam.fullPathName()\n        cameraTrans = mc.listRelatives(camPath,type='transform',p=True)\n        camPivot = mc.xform(cameraTrans, q=1, ws=1, rp=1)\n        if mc.objExists('instCutPlane'):\n            selectionList = om.MSelectionList()\n            selectionList.add('instCutPlane')\n            dagPath = om.MDagPath()\n            selectionList.getDagPath(0, dagPath)\n            fnMeshA = om.MFnMesh(dagPath)\n            global ctxPlane\n            ctxPlane = 'drawPlane'\n            if mc.draggerContext(ctxPlane, exists=True):\n                mc.deleteUI(ctxPlane)\n            mc.draggerContext(ctxPlane, pressCommand = X8I, rc = Xlo, dragCommand = X25, name=ctxPlane, fnz=X85, cursor='crossHair',undoMode='step')\n            mc.setToolTo(ctxPlane)\n            mc.scriptJob(runOnce=True, event=[\"ToolChanged\", X75])\n\ndef X75():\n    points = [(0, 0, 0), (0, 0, 0), (0, 0, 0)]\n    mesh = mc.polyCreateFacet(p=points, n='tempExtrudeBlock')\n    if mc.objExists(\"cutBlockShader\") == 0:\n        shader=mc.shadingNode(\"surfaceShader\", name = 'cutBlockShader',asShader=True)\n        shading_group= mc.sets(name='cutBlockShaderSG',renderable=True,noSurfaceShader=True,empty=True)\n        mc.connectAttr('cutBlockShader.outColor', 'cutBlockShaderSG.surfaceShader',f=1 )\n        mc.setAttr(\"cutBlockShader.outColor\", 0.65, 0, 0.85, type=\"double3\")\n        mc.setAttr(\"cutBlockShader.outTransparency\", 0.85, 0.85, 0.85, type=\"double3\")\n    if mc.objExists(\"cutGirdLine\"):\n        mc.setAttr(\"cutGirdLine.lineColor\", 0.25, 1, 1, type=\"double3\")\n    if mc.objExists(\"tempExtrudeBlock\"):\n        mc.select('tempExtrudeBlock')\n        mc.setAttr('tempExtrudeBlock.hiddenInOutliner',1)\n    cutMode = mc.radioButtonGrp('cutMode', q=1, sl=1)\n    if cutMode == 1:\n        mc.setAttr(\"cutBlockShader.outColor\", 0.65, 0, 0.85, type=\"double3\")\n    else:\n        mc.setAttr(\"cutBlockShader.outColor\", 0, 1, 0.2, type=\"double3\")\n    mc.hyperShade(assign=\"cutBlockShader\") \n    if mc.objExists(\"instCutPlane\"):\n        selectionList = om.MSelectionList()\n        selectionList.add('instCutPlane')\n        dagPath = om.MDagPath()\n        selectionList.getDagPath(0, dagPath)\n        fnMeshA = om.MFnMesh(dagPath)\n        global ctx\n        ctx = 'drawBlock'\n        if mc.draggerContext(ctx, exists=True):\n            mc.deleteUI(ctx)\n        mc.draggerContext(ctx, pressCommand = Xo6, rc = X94, dragCommand = X79, name=ctx, cursor='crossHair',undoMode='step')\n        #mc.draggerContext(ctx, pressCommand = Xo6, rc = X94, dragCommand = cutDragMove, name=ctx, cursor='crossHair',undoMode='step')\n        mc.setToolTo(ctx)\n        cutToolID = mc.scriptJob(runOnce=True, event=[\"ToolChanged\", XI5])\n\ndef XI5():\n    if mc.objExists(\"tempExtrudeBlock\"):\n        face_count = mc.polyEvaluate('tempExtrudeBlock', face=True)\n        if face_count > 1:\n            getLarge = X98()\n            allFace = mc.ls('tempExtrudeBlock.f[*]',fl=1)\n            allFace.remove(getLarge)\n            mc.delete(allFace)\n        cutPlanePivot = mc.xform('instCutPlane', q=1, ws=1, rp=1)\n        global targetMmesh\n        global oldShader\n        global extrudeNewMesh\n        global targetMmeshScale\n        global curExtrudeCount\n        global recordHitPoint\n        #recordHitPoint = [0,0,0]\n        curExtrudeCount = 0.1 * targetMmeshScale\n        normal1 = X38('instCutPlane', 0)\n        normal2 = X38('tempExtrudeBlock', 0)\n        normal1.normalize()\n        no